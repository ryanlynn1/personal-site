---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found" description="Page not found.">
  <section class="container notfound">
    <span class="eyebrow">404</span>
    <h1 class="notfound-title">Page not found.</h1>
    <p class="notfound-intro">The page you’re looking for doesn’t exist or has moved.</p>
    <a class="accent-link" href="/">
      Back home <span class="arrow" aria-hidden="true">→</span>
    </a>
  </section>
</Layout>

<style>
  .notfound-title {
    margin-top: 14px;
    font-size: clamp(2.2rem, 5.5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--text-strong);
  }
  .notfound-intro {
    margin-top: 18px;
    font-size: 1.1rem;
    color: var(--text-muted);
  }
  .notfound .accent-link {
    margin-top: 24px;
  }
</style>
