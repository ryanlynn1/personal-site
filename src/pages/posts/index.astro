---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostRow from '../../components/PostRow.astro';
import { categoryLabel } from '../../lib/categories';
import { blogSchema, breadcrumbSchema } from '../../lib/schema';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const years = [...new Set(posts.map((p) => p.data.publishedAt.getUTCFullYear()))].sort(
  (a, b) => b - a
);
const byYear = years.map((year) => ({
  year,
  items: posts.filter((p) => p.data.publishedAt.getUTCFullYear() === year),
}));

// Categories present, in canonical order
const order = ['ai-strategy', 'implementation', 'industry-insights', 'case-analysis', 'leadership', 'news'];
const present = new Set(posts.map((p) => p.data.category));
const categories = order.filter((c) => present.has(c));

const jsonLd = [
  blogSchema(posts),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Posts', path: '/posts' },
  ]),
];
---

<Layout
  title="Posts"
  description="Every essay on building production AI agents, real-world implementation, and what’s next."
  jsonLd={jsonLd}
>
  <section class="container archive">
    <span class="eyebrow">Archive</span>
    <h1 class="archive-title">Writing.</h1>

    <div class="filter-chips" aria-label="Filter posts by category">
      <button class="chip is-active" data-cat="all" type="button">All</button>
      {
        categories.map((c) => (
          <button class="chip" data-cat={c} type="button">
            {categoryLabel(c)}
          </button>
        ))
      }
    </div>

    <p class="no-results" hidden>No posts in this topic yet.</p>

    {
      byYear.map((group) => (
        <section class="year-group">
          <h2 class="year-label">{group.year}</h2>
          <div class="year-posts">
            {group.items.map((post) => (
              <PostRow post={post} showCategory />
            ))}
          </div>
        </section>
      ))
    }
  </section>
</Layout>

<style>
  .archive-title {
    margin-top: 14px;
    font-size: clamp(2.2rem, 5.5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--text-strong);
  }
  .archive-intro {
    margin-top: 18px;
    max-width: 38rem;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 28px;
  }
  .chip {
    padding: 7px 15px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    font-size: 0.82rem;
    color: var(--text-muted);
    background: transparent;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }
  .chip:hover {
    color: var(--text-strong);
    border-color: var(--text-faint);
  }
  .chip.is-active {
    color: var(--accent);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 13%, transparent);
    font-weight: 600;
  }

  .no-results {
    margin-top: 40px;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .year-group {
    margin-top: 48px;
  }
  .year-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .year-posts {
    margin-top: 8px;
  }
</style>

<script is:inline>
  (function () {
    const chips = Array.from(document.querySelectorAll('.filter-chips .chip'));
    const groups = Array.from(document.querySelectorAll('.year-group'));
    const noResults = document.querySelector('.no-results');
    if (!chips.length) return;

    function apply(cat) {
      let totalVisible = 0;
      groups.forEach((group) => {
        let visibleInGroup = 0;
        group.querySelectorAll('.post-row[data-category]').forEach((row) => {
          const show = cat === 'all' || row.getAttribute('data-category') === cat;
          row.style.display = show ? '' : 'none';
          if (show) visibleInGroup++;
        });
        group.style.display = visibleInGroup > 0 ? '' : 'none';
        totalVisible += visibleInGroup;
      });
      if (noResults) noResults.hidden = totalVisible > 0;
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.toggle('is-active', c === chip));
        apply(chip.getAttribute('data-cat'));
      });
    });
  })();
</script>
