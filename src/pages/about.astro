---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const photos = [
  { src: '/founder.JPG', alt: 'Ryan running a garage sale as a kid', caption: 'Where it started' },
  { src: '/award.jpg', alt: 'Ryan receiving Sales Rep of the Year at SS&C Intralinks', caption: 'Sales Rep of the Year — SS&C Intralinks' },
  { src: '/building.jpg', alt: 'Ryan building IntelligentNoise', caption: 'Building IntelligentNoise' },
];
---

<Layout
  title="About"
  description="Ryan Lynn — from garage sales and enterprise software sales to founding IntelligentNoise, the AI platform for revenue teams."
>
  <article class="about">
    <span class="eyebrow">About</span>
    <h1 class="about-title">Hey — I'm Ryan.</h1>

    <div class="about-body">
      <p class="lead">
        I've been building things for as long as I can remember — and after a long detour through
        corporate America, I left to build <strong>IntelligentNoise</strong>, the AI platform for
        revenue teams.
      </p>

      <p>
        I grew up in an entrepreneurial house. My dad was a tech entrepreneur in the early-internet
        days; my mom ran a home-goods store on Main Street. I was the kid running garage sales — and
        getting in trouble in fourth grade for reselling Wacky Packages to my classmates.
      </p>

      <p>
        Then I did the sensible thing. Seven years in corporate America: management consulting at
        Grant Thornton, then enterprise software sales at SS&amp;C Intralinks, where I was named
        <strong>Sales Rep of the Year</strong>. I learned how big companies actually buy, sell, and
        run — and I watched revenue teams spend most of their day on work that software should just…
        do.
      </p>

      <p class="beat">Then AI changed everything.</p>

      <p>
        What used to take a team of engineers, months of work, and real infrastructure can now be
        built by a small team in a weekend — with the right insight and the right tools. The
        barriers dropped. The playing field leveled.
      </p>

      <p class="beat">So I left to build it.</p>

      <p>
        IntelligentNoise is the AI platform for revenue teams — production AI agents that do the
        work, not just demo well. It's the thing I wish I'd had in every sales seat I ever sat in.
      </p>
    </div>

    <figure class="quote">
      <blockquote>
        "For a long time, technical people in the startup industry have made fun of 'the idea guys'
        — people who had an idea and were looking for a team to build it. It now looks to me like
        they are about to have their day in the sun."
      </blockquote>
      <figcaption>— Sam Altman, CEO of OpenAI</figcaption>
    </figure>

    <div class="photo-strip">
      {
        photos.map((p) => (
          <figure class="photo">
            <img src={p.src} alt={p.alt} loading="lazy" />
            <figcaption>{p.caption}</figcaption>
          </figure>
        ))
      }
    </div>

    <div class="about-body">
      <p>
        I'm finishing my MBA (concentration in Artificial Intelligence) at Michigan Ross, and I
        write here about what I'm learning building production agents in the real world — what works,
        what breaks, and what's next.
      </p>
      <p class="close">
        You don't need a green light. You don't need permission. You just need to start.
      </p>
      <p class="signoff">Onward,<br />Ryan</p>
    </div>

    <div class="byline">
      <img class="byline-avatar" src={site.avatar} alt="Ryan Lynn" width="52" height="52" />
      <div class="byline-meta">
        <span class="byline-name">Ryan Lynn</span>
        <span class="byline-role">Founder, IntelligentNoise</span>
        <span class="byline-tag">Ex-garage sales · Ex-consulting · Ex-SaaS · bootstrapped AI founder</span>
      </div>
    </div>
  </article>
</Layout>

<style>
  .about {
    max-width: 46rem;
    margin: 0 auto;
    padding-inline: 24px;
  }
  .about-title {
    margin-top: 14px;
    font-size: clamp(2.2rem, 5.5vw, 3.1rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--text-strong);
  }

  .about-body {
    margin-top: 28px;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text);
  }
  .about-body p {
    margin-block: 1.2em;
  }
  .about-body strong {
    color: var(--text-strong);
    font-weight: 650;
  }
  .about-body .lead {
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--text-strong);
    margin-top: 0;
  }
  .about-body .beat {
    font-size: 1.25rem;
    font-weight: 650;
    color: var(--text-strong);
    letter-spacing: -0.01em;
  }
  .about-body .close {
    font-weight: 600;
    color: var(--text-strong);
  }
  .about-body .signoff {
    color: var(--text-muted);
  }

  .quote {
    margin: 40px 0;
    padding: 4px 0 4px 22px;
    border-left: 3px solid var(--accent);
  }
  .quote blockquote {
    font-size: 1.2rem;
    line-height: 1.55;
    font-style: italic;
    color: var(--text-strong);
  }
  .quote figcaption {
    margin-top: 12px;
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .photo-strip {
    margin: 40px 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .photo {
    margin: 0;
  }
  .photo img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border);
  }
  .photo figcaption {
    margin-top: 8px;
    font-size: 0.78rem;
    color: var(--text-faint);
    text-align: center;
  }

  .byline {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .byline-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }
  .byline-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.4;
  }
  .byline-name {
    font-weight: 650;
    color: var(--text-strong);
  }
  .byline-role {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .byline-tag {
    font-size: 0.82rem;
    color: var(--accent);
    margin-top: 2px;
  }

  @media (max-width: 560px) {
    .photo-strip {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .photo img {
      aspect-ratio: 16 / 10;
    }
  }
</style>
