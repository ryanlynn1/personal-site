---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import WorkRail from '../components/WorkRail.astro';
import PostRow from '../components/PostRow.astro';
import { site } from '../data/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
const latest = posts[0];
const rest = posts.slice(1, 6);
---

<Layout>
  <section class="container hero">
    <h1 class="hero-title">{site.heroTitle}</h1>
    <p class="hero-intro">{site.heroIntro}</p>

    {
      latest && (
        <div class="latest">
          <span class="eyebrow">Latest</span>
          <h2 class="latest-title">
            <a href={`/posts/${latest.id}`}>{latest.data.title}</a>
          </h2>
          <p class="latest-excerpt">{latest.data.excerpt}</p>
          <a class="accent-link" href={`/posts/${latest.id}`}>
            Read the essay <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      )
    }
  </section>

  <div class="container"><hr class="divider" /></div>

  <div class="container home-grid">
    <div class="posts-col">
      {rest.map((post) => <PostRow post={post} />)}
      <a class="accent-link view-all" href="/posts">
        View all posts <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <div class="rail-col">
      <WorkRail />
    </div>
  </div>
</Layout>

<style>
  .hero-title {
    font-size: clamp(2.4rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--text-strong);
  }
  .hero-intro {
    margin-top: 24px;
    max-width: 40rem;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .latest {
    margin-top: clamp(48px, 8vw, 84px);
  }
  .latest-title {
    margin-top: 14px;
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text-strong);
  }
  .latest-title a {
    transition: color 0.15s ease;
  }
  .latest-title a:hover {
    color: var(--accent);
  }
  .latest-excerpt {
    margin-top: 12px;
    max-width: 42rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-muted);
  }
  .latest .accent-link {
    margin-top: 18px;
    font-size: 1rem;
  }

  .home-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 56px;
    align-items: start;
  }
  .view-all {
    margin-top: 30px;
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: 44px;
    }
  }
</style>
